# ──────────────────────────────────────────────────────────────
# Configuration locale — copier ce fichier en `.env` et remplir.
# Sur Vercel : les variables sont déjà injectées par l'intégration
# Supabase, rien à faire côté prod.
# ──────────────────────────────────────────────────────────────

# Connection string PostgreSQL Supabase
# Dashboard Supabase > Project Settings > Database
#   > Connection string > URI (mode "Session pooler" pour usage normal,
#     ou "Direct connection" pour les imports bulk comme import_to_db.py)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Client Supabase pour le front Next.js
# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé service_role (server-side uniquement, NE JAMAIS exposer côté client)
# Utile pour des scripts d'admin / Edge Functions privilégiées
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
